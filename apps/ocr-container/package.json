{
  "name": "@aleph-ocr/ocr-container",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "uvicorn src.main:app --host 127.0.0.1 --port 8090 --reload",
    "build": "python -m py_compile src/main.py src/ocr_engine.py",
    "lint": "python -m py_compile src/main.py src/ocr_engine.py",
    "test": "python -m py_compile src/main.py src/ocr_engine.py",
    "clean": "rm -rf __pycache__ src/__pycache__ .pytest_cache"
  }
}
