{
  "name": "@aleph-tools/tools-container",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "uvicorn src.main:app --host 127.0.0.1 --port 8090 --reload",
    "build": "python3 -m py_compile src/main.py src/ocr_engine.py src/image_tools.py",
    "lint": "python3 -m py_compile src/main.py src/ocr_engine.py src/image_tools.py",
    "test": "python3 -m py_compile src/main.py src/ocr_engine.py src/image_tools.py && python3 scripts/test-image-tools.py",
    "clean": "rm -rf __pycache__ src/__pycache__ .pytest_cache"
  }
}
