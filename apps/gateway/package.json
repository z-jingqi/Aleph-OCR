{
  "name": "@aleph-tools/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.local.jsonc --port 8787",
    "deploy": "wrangler deploy --config wrangler.local.jsonc",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "d1:migrate:local": "wrangler d1 migrations apply aleph-tools-local --local --config wrangler.local.jsonc",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@aleph-tools/shared": "workspace:*",
    "@cloudflare/containers": "^0.3.7",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.104.0"
  }
}
